#!/usr/bin/env bash
# Run Gradle with JDK 17 (required — JDK 26 is not supported by Gradle 8.9 / AGP 8.7).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

if [ -z "${JAVA_HOME:-}" ] || ! "$JAVA_HOME/bin/java" -version 2>&1 | grep -q '"17'; then
  for candidate in \
    /usr/lib/jvm/java-17-openjdk \
    /usr/lib/jvm/java-17 \
    "$HOME/.sdkman/candidates/java/17"*/; do
    if [ -x "${candidate%/}/bin/java" ] && "${candidate%/}/bin/java" -version 2>&1 | grep -q '"17'; then
      export JAVA_HOME="${candidate%/}"
      break
    fi
  done
fi

if [ -z "${JAVA_HOME:-}" ]; then
  echo "ERROR: JDK 17 not found. Install it (e.g. pacman -S jdk17-openjdk) and retry." >&2
  exit 1
fi

export PATH="$JAVA_HOME/bin:$PATH"
export GRADLE_USER_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}"

echo "Using JAVA_HOME=$JAVA_HOME"
exec ./gradlew "$@"
